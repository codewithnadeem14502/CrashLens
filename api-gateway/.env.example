PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_CREDENTIALS=false
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=JWT_SECRET
# Must match the issuer auth-service signs access tokens with
# (auth-service/src/utils/tokens.js) - defaults to the same value there.
ACCESS_TOKEN_ISSUER=crash-lens-auth-service

# Redis-backed rate limiting (middleware/rateLimiter.js)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# Differenet services URL
AUTH_SERVICE_URL=http://127.0.0.1:3001
PROJECT_SERVICE_URL=http://127.0.0.1:3002
EVENT_SERVICE_URL=http://127.0.0.1:3003
ISSUE_SERVICE_URL=http://127.0.0.1:3005
MONITOR_SERVICE_URL=http://127.0.0.1:3006
ALERT_SERVICE_URL=http://127.0.0.1:3007
