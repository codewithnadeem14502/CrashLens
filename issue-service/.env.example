PORT=3005
MONGODB_URI=mongodb://localhost:27017/issue-service?retryWrites=false
NODE_ENV=development
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=false
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=crashlens.events
ISSUE_OCCURRENCE_QUEUE=issue-service.occurrence-processing
ISSUE_OCCURRENCE_RETRY_QUEUE=issue-service.occurrence-processing.retry
ISSUE_OCCURRENCE_DLQ=issue-service.occurrence-processing.dlq
ISSUE_PREFETCH=10
ISSUE_RETRY_DELAY_MS=30000
MAX_RETRY_ATTEMPTS=3
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_ISSUER=crash-lens-auth-service
