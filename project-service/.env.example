PORT=3002
MONGODB_URI=mongodb://localhost:27017/project-service?retryWrites=false
NODE_ENV=development
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=false
REDIS_URL=redis://localhost:6379
PROJECT_CACHE_TTL_SECONDS=120
PROJECT_DSN_CACHE_TTL_SECONDS=300
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=crashlens.events
# Module 2: bounded retry + DLQ for project lifecycle event publish failures
PROJECT_EVENTS_DLQ=project-service.events.dlq
MAX_RETRY_ATTEMPTS=3
PROJECT_EVENTS_RETRY_DELAY_MS=500
PROJECT_EVENTS_DLQ_TTL_MS=2592000000
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_ISSUER=crash-lens-auth-service
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=7
