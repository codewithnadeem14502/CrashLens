PORT=3007
MONGODB_URI=mongodb://localhost:27017/alert-service?retryWrites=false
NODE_ENV=development
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=false
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_ISSUER=crash-lens-auth-service
# Direct-to-service URLs (not via api-gateway) for the query executor's
# inter-service reads - same env var names api-gateway itself uses to
# reach these services.
ISSUE_SERVICE_URL=http://127.0.0.1:3005
MONITOR_SERVICE_URL=http://127.0.0.1:3006
SERVICE_CALL_TIMEOUT_MS=8000
# How often the background sweep checks which alert rules are due -
# distinct from each rule's own evaluationIntervalSeconds (the per-rule
# cadence), same relationship as monitor-service's *_SWEEP_INTERVAL_MS.
ALERT_EVALUATION_SWEEP_INTERVAL_MS=15000
ALERT_EVENT_TTL_SECONDS=7776000
# Email notification action (nodemailer) - optional; email actions fail
# gracefully (recorded as a failed delivery, other actions unaffected) if
# SMTP_HOST is unset.
#
# Quickest real-SMTP option (Gmail/Google Workspace):
#   1. Turn on 2-Step Verification on the sending Google account, if not
#      already on: https://myaccount.google.com/security
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#      (name it e.g. "crashlens-alerts") - copy the 16-character password.
#   3. Fill in SMTP_USER (the full Gmail/Workspace address) and SMTP_PASS
#      (the app password, not the account's real login password) below.
# Gmail's SMTP_HOST/PORT/SECURE values are already filled in as the default
# here - swap them for another provider's (SES/SendGrid/Postmark/Resend) if
# you outgrow Gmail's ~500-2000 email/day cap later; SMTP_USER/PASS/FROM
# are the only fields that change.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Generic webhook notification action
WEBHOOK_TIMEOUT_MS=8000
