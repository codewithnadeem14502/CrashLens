PORT=3004
MONGODB_URI=mongodb://localhost:27017/worker-service?retryWrites=false
NODE_ENV=development
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=false
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=crashlens.events
WORKER_EVENT_QUEUE=worker-service.event-ingestion
WORKER_EVENT_RETRY_QUEUE=worker-service.event-ingestion.retry
WORKER_EVENT_DLQ=worker-service.event-ingestion.dlq
WORKER_PREFETCH=10
MAX_RETRY_ATTEMPTS=3
WORKER_RETRY_DELAY_MS=30000
