PORT=3006
MONGODB_URI=mongodb://localhost:27017/monitor-service?retryWrites=false
NODE_ENV=development
LOG_LEVEL=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=false
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_EXCHANGE=crashlens.events
MONITOR_EVENTS_DLQ=monitor-service.events.dlq
MAX_RETRY_ATTEMPTS=3
MONITOR_EVENTS_RETRY_DELAY_MS=500
MONITOR_EVENTS_DLQ_TTL_MS=2592000000
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_ISSUER=crash-lens-auth-service
# Missed-checkin + timeout sweep tick interval
CRON_SWEEP_INTERVAL_MS=30000
# Uptime prober tick interval - actual per-monitor probe cadence is each
# UptimeMonitor's own intervalSeconds; this is just how often the service
# checks which monitors are due
UPTIME_PROBE_INTERVAL_MS=15000
# Check-in / uptime-check history retention (TTL)
CHECKIN_TTL_SECONDS=7776000
UPTIME_CHECK_TTL_SECONDS=7776000
