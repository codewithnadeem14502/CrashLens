# Copy this to `.env` (git-ignored, never commit it) at the repo root and
# fill in real values before running `docker compose up`. This is the ONE
# env file docker-compose.yml reads via ${VAR} substitution - it is separate
# from each service's own .env.example (which documents that service's
# local-dev defaults).

# ---------------------------------------------------------------------------
# Domain (must already point at this VM's public IP via an A record)
# ---------------------------------------------------------------------------
DOMAIN=api.crashlens.online

# ---------------------------------------------------------------------------
# MongoDB Atlas - base connection string, WITHOUT a trailing database name or
# path. Each service appends its own /<service-name> in docker-compose.yml.
# Example: mongodb+srv://<user>:<password>@cluster0.1ydh1vq.mongodb.net
# Rotate the password in Atlas before pasting a real one here, and never
# paste it anywhere but this git-ignored file.
# ---------------------------------------------------------------------------
MONGODB_BASE_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net

# ---------------------------------------------------------------------------
# Shared auth secret - MUST be identical across api-gateway, auth-service,
# project-service, issue-service, monitor-service, and alert-service (auth
# signs tokens, the rest verify/mint them). Generate with e.g.:
#   openssl rand -hex 64
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# CORS - the exact origin(s) allowed to call the gateway from a browser.
# Must match the deployed frontend origin exactly (scheme + host, no
# trailing slash). Comma-separate if there's more than one.
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://crash-lens-client.vercel.app

# ---------------------------------------------------------------------------
# alert-service email notifications (optional). Leave blank to disable -
# email actions then fail gracefully without affecting other alert actions.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@crashlens.local
